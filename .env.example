# ---------------------------------------------------------------------------
# Database (PostgreSQL)
#
# LOCAL (Docker): the bundled docker-compose.yml works with this as-is.
#   postgresql://arabic:arabic@localhost:5432/arabic_vocab?schema=public
#
# REMOTE / CLOUD (use the SAME db from multiple laptops): paste the connection
# string from your provider (Neon, Supabase, Railway, etc.). It must include
# SSL, e.g. append `&sslmode=require` (Neon also wants the pooled host).
#   postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://arabic:arabic@localhost:5432/arabic_vocab?schema=public"

# ---------------------------------------------------------------------------
# Auth
# Generate a strong secret, e.g.:  openssl rand -base64 32
# ---------------------------------------------------------------------------
AUTH_SECRET="change-me-to-a-long-random-string"

# ---------------------------------------------------------------------------
# AI provider
#   AI_PROVIDER: "openai" (any OpenAI-compatible endpoint) | "mock"
#   When AI_API_KEY is empty or AI_PROVIDER=mock, the app falls back to a
#   deterministic offline engine so grading & lessons still work (no network).
# ---------------------------------------------------------------------------
AI_PROVIDER="openai"
AI_API_KEY=""
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4o-mini"
